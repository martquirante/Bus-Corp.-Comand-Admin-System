# Shared local development values
ADMIN_WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# API server
PORT=4000
NODE_ENV=development
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=160
SESSION_SECRET=replace-with-a-long-random-string

# Firebase Admin SDK. Never expose these in the frontend.
FIREBASE_PROJECT_ID=santranspos
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@santranspos.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://santranspos-default-rtdb.firebaseio.com

# Development-only fallback. Keep false in production.
ENABLE_DEMO_FALLBACK=true
DEMO_ADMIN_EMAIL=admin@posticketing.com
DEMO_ADMIN_PASSWORD=admin123
